#!/bin/bash
# MiMo Code install callback v0.12.6
# - fpk 已被 fnpack 解压到 ${TRIM_APPDEST}（含 server/、ui/）
# - 补齐 /var/apps/mimocode/ui，fnOS 桌面入口需要 root ui/config
# - 仅做：建数据目录、给可执行权限、创建 /usr/local/bin/mimo 软链

set -u

APP_NAME="mimocode"
TRIM_APPDEST="${TRIM_APPDEST:-/vol3/@appcenter/${APP_NAME}}"
TRIM_PKGVAR="${TRIM_PKGVAR:-/vol3/@appdata/${APP_NAME}}"

SERVER_DIR="${TRIM_APPDEST}/server"
LOG="${TRIM_TEMP_LOGFILE:-${TRIM_PKGVAR}/install.log}"

mkdir -p "${TRIM_PKGVAR}/var" "${TRIM_PKGVAR}/etc" "${TRIM_PKGVAR}/mimo_home"

if [ ! -f "${SERVER_DIR}/mimo" ]; then
    echo "[$(date '+%F %T')] mimo binary missing at ${SERVER_DIR}/mimo" > "$LOG"
    exit 1
fi

# 权限
chmod 755 "${SERVER_DIR}/mimo" "${SERVER_DIR}/uwrapper.py" 2>/dev/null || true
[ -d "${SERVER_DIR}/public" ] && chmod -R 755 "${SERVER_DIR}/public" 2>/dev/null || true
[ -d "${SERVER_DIR}/mimo_assets" ] && chmod -R 755 "${SERVER_DIR}/mimo_assets" 2>/dev/null || true
[ -f "${SERVER_DIR}/mimo_assets/cache/bin/rg" ] && chmod 755 "${SERVER_DIR}/mimo_assets/cache/bin/rg" 2>/dev/null || true

# fnOS 桌面入口老坑：桌面按 desktop_uidir=ui 读取 /var/apps/<app>/ui/config，
# 不能只依赖 /var/apps/<app>/target/ui/config。重装/升级后必须补 root ui。
ROOT_UI="/var/apps/${APP_NAME}/ui"
SRC_UI="${TRIM_APPDEST}/ui"
if [ -d "${SRC_UI}" ]; then
    rm -rf "${ROOT_UI}"
    cp -a "${SRC_UI}" "${ROOT_UI}"
    chown -R root:root "${ROOT_UI}" 2>/dev/null || true
    chmod -R a+rX "${ROOT_UI}" 2>/dev/null || true
else
    echo "[$(date '+%F %T')] ui source missing at ${SRC_UI}" >> "$LOG"
fi

# CLI 软链：方便用户 SSH 后直接运行 mimo
ln -sf "${SERVER_DIR}/mimo" /usr/local/bin/mimo 2>/dev/null || true

echo "[$(date '+%F %T')] install_callback OK: ${SERVER_DIR}" >> "$LOG"
exit 0
