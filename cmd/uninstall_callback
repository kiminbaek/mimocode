#!/bin/bash
# MiMo Code uninstall callback v0.11.8

LOG_FILE="${TRIM_PKGVAR}/uninstall.log"
mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true

log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE" 2>/dev/null || true
}

log_msg "=== MiMo Code uninstall start ==="

for pid_file in "${TRIM_PKGVAR}/wrapper.pid" "${TRIM_PKGVAR}/mimo.pid"; do
    if [ -f "$pid_file" ]; then
        pid=$(cat "$pid_file" 2>/dev/null || true)
        [ -n "$pid" ] && kill "$pid" 2>/dev/null || true
        sleep 0.3
        [ -n "$pid" ] && kill -9 "$pid" 2>/dev/null || true
        rm -f "$pid_file"
    fi
done
pkill -f "uwrapper.py 5670" 2>/dev/null || true
pkill -f "mimo web.*--port 5669" 2>/dev/null || true
log_msg "processes stopped"

if [ -L "/usr/local/bin/mimo" ]; then
    rm -f "/usr/local/bin/mimo" 2>/dev/null || true
    log_msg "symlink removed: /usr/local/bin/mimo"
fi

rm -rf "${TRIM_APPDEST}/bin" "${TRIM_APPDEST}/server" 2>/dev/null || true
log_msg "target binary/server removed"

DELETE_DATA="${wizard_delete_data:-false}"
KEEP_CONFIG="${wizard_keep_config:-true}"  # backward compatibility with older wizard

if [ "$DELETE_DATA" = "true" ] || [ "$KEEP_CONFIG" != "true" ]; then
    rm -rf "${TRIM_PKGVAR}"/* 2>/dev/null || true
    rm -rf "${TRIM_PKGETC}" 2>/dev/null || true
    rm -rf "${TRIM_PKGHOME}" 2>/dev/null || true
    # Legacy profile used before v0.11.6. New profile is under ${TRIM_PKGVAR}/mimo_home.
    rm -rf "/root/.config/mimocode" "/root/.local/share/mimocode" "/root/.local/state/mimocode" "/root/.cache/mimocode" 2>/dev/null || true
    log_msg "config and runtime data removed by wizard choice"
else
    rm -f "${TRIM_PKGVAR}/wrapper.pid" "${TRIM_PKGVAR}/mimo.pid" 2>/dev/null || true
    log_msg "config and data kept: ${TRIM_PKGETC}, ${TRIM_PKGVAR}, ${TRIM_PKGHOME}"
fi

exit 0
